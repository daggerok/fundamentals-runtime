{
  "name": "fundamentals-runtime",
  "source": "src/index.html",
  "private": true,
  "scripts": {
    "serve:www": "bunx serve .",
    "serve:proxy-www": "bunx local-cors-proxy --proxyUrl https://www.sec.gov --port 8011",
    "serve:proxy-data": "bunx local-cors-proxy --proxyUrl https://data.sec.gov --port 8012",
    "serve": "npm-run-all --parallel serve:*",
    "start": "pm2 start 'npm run serve' --name app",
    "restart": "pm2 restart app",
    "ps": "pm2 ps",
    "logs": "pm2 logs",
    "stop": "pm2 kill"
  },
  "devDependencies": {
    "npm-run-all": "4.1.5",
    "pm2": "7.0.3"
  }
}
